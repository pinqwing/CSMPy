

0001 from csmp import MACRO, TITLE, PARAM, CONSTANT, METHOD, TIMER, OUTPUT, PRINT
0002 from csmp.functions import EXP, AMIN1
0003 from csmp import Clip
0004 
0005 TITLE("DRY MATTER PRODUCTION")
0006 
0007 MACRO("""
0008     X, DXDT  = EXPONENTIAL(X0, A, B)
0009     X        = INTGRL(X0, DXTD)
0010     DXDT     = A * (X - B)
0011     """)
0012     
0013 TWT     = WSH + WRT
0014 WSH     = INTGRL(WSHI, GSH)
0015 WRT     = INTGRL(WRTI, GRT)
0016 WSHI    = INCON(50.)
0017 WRTI    = INCON(50.)
0018 GSH     = 0.7 * GTW
0019 GRT     = 0.3 * GTW
0020 GTW     = (GPHOT - MAINT) * CVF
0021 MAINT   = (WSH + WRT) * 0.015
0022 GPHOT   = GPHST * (1. - EXP(-0.7 * LAI))
0023 LAI     = AMIN1(WSH / 500.,  5.)
0024 EX1, R1 = EXPONENTIAL(10., 0.1, 5) # test macro
0025 EX2, R2 = EXPONENTIAL(WRTI, CVF, GPHST / 5.) # test macro
0026 REDFT   = FUNCTION(0.,1.,0.2,1.,0.25,0.,0.5,0.)
0027 REDFT1   = FUNCTION(0.,1.,0.2,1.,0.25,0.,0.5,0.)
0028 REDFT2   = FUNCTION(0.,1.,0.2,1.,0.25,0.,0.5,0.)
0029 REDF    = AFGEN(REDFT,LAI*4 - R1, extra=Clip)
0030 REDF2    = AFGEN(REDFT,LAI*4 - R1, extra=Clip)
0031 REDF2    = AFGEN(REDFT,LAI*4 - R1, extra=Clip)
0032 PARAM(
0033     CVF = 0.7, 
0034     GPHST = 400.,
0035     PPI = PI    # test param depeding on constant
0036     )
0037 CONSTANT(
0038     PI = 3.141592,
0039     PI2 = 2 * PI,   # test of dependent constant
0040     )      
0041 
0042 TIMER(FINTIM = 100., DELT = 1., PRDEL = 5., OUTDEL = 5.)
0043 METHOD("RECT")
0044 PRINT(TWT, WSH, WRT, GTW)
0045 OUTPUT(TWT)
0046 


       0 error(s)
       0 warning(s)
