

0001 from csmp.keywords import MACRO, TITLE, PARAM, CONSTANT, METHOD, TIMER, OUTPUT, PRINT
0002 from csmp.functions import EXP, AMIN1
0003 
0004 TITLE("DRY MATTER PRODUCTION")
0005 
0006 MACRO("""
0007     X, DXDT  = EXPONENTIAL(X0, A, B)
0008     X        = INTGRL(X0, DXTD)
0009     DXDT     = A * (X - B)
0010     """)
0011     
0012 TWT     = WSH + WRT
0013 WSH     = INTGRL(WSHI, GSH)
0014 WRT     = INTGRL(WRTI, GRT)
0015 WSHI    = INCON(50.)
0016 WRTI    = INCON(50.)
0017 GSH     = 0.7 * GTW
0018 GRT     = 0.3 * GTW
0019 GTW     = (GPHOT - MAINT) * CVF
0020 MAINT   = (WSH + WRT) * 0.015
0021 GPHOT   = GPHST * (1. - EXP(-0.7 * LAI))
0022 LAI     = AMIN1(WSH / 500.,  5.)
0023 EX1, R1 := EXPONENTIAL(10., 0.1, 5) # test macro
0024 EX2, R2 = EXPONENTIAL(WRTI, CVF, GPHST / 5.) # test macro
0025  
0026 PARAM(
0027     CVF = 0.7, 
0028     GPHST = 400.,
0029     PPI = PI    # test param depeding on constant
0030     )
0031 CONSTANT(
0032     PI = 3.141592,
0033     PI2 = 2 * PI,   # test of dependent constant
0034     )      
0035 
0036 TIMER(FINTIM = 100., DELT = 1., PRDEL = 5., OUTDEL = 5.)
0037 METHOD("RECT")
0038 PRINT(TWT, WSH, WRT, GTW)
0039 OUTPUT(TWT)
